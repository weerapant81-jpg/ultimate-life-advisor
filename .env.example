RESEND_API_KEY=
APPOINTMENT_TO_EMAIL=weerapan.aia@hotmail.com
APPOINTMENT_FROM_EMAIL=Ultimate Life Advisor <onboarding@resend.dev>

# Cloudflare Turnstile (anti-bot CAPTCHA on the appointment form).
# Get both keys from the Cloudflare dashboard: Turnstile > Add site.
# VITE_ prefix is required so the site key reaches the frontend build.
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Sentry error monitoring (optional; absent = disabled).
# Create a project at sentry.io to get the DSNs. VITE_ one is for the frontend.
SENTRY_DSN=
VITE_SENTRY_DSN=
